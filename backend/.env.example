# --- 穗安 SuiAn .env ---
# 拷成 .env 后填值。所有项都是可选的，留空则走规则回退。

# === 数据库 ===
SUIAN_DB_PATH=./suian.db

# === 天气源 ===
# 默认 Open-Meteo（零 key，无需注册），按 seed/weather_api_notes.md 实现
OPENMETEO_BASE=https://api.open-meteo.com/v1
# 如果要切换到和风天气（中文预警精），填以下两项
QWEATHER_HOST=
QWEATHER_TOKEN=

# === LLM ===
# 支持 deepseek | qwen | moonshot | anthropic | none
# 留空或 none → Decision Agent 走规则模板（仍可 demo）
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# === 服务 ===
HOST=0.0.0.0
PORT=8000
