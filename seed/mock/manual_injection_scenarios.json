      "narrative_hook": "演讲到'如果你是种了 320 亩小麦的老李头'，按这个按钮。",
      "inject": {
        "parcel_id": "P-HEB-GUANTAO-001",
        "weather_override": {
          "daily": [
            {"date": "2026-05-26", "tmax": 27, "tmin": 18, "precip_mm": 0,  "rh_max": 70, "wind_max_ms": 3},
            {"date": "2026-05-27", "tmax": 25, "tmin": 19, "precip_mm": 2,  "rh_max": 82, "wind_max_ms": 3},
            {"date": "2026-05-28", "tmax": 22, "tmin": 19, "precip_mm": 18, "rh_max": 92, "wind_max_ms": 2},
            {"date": "2026-05-29", "tmax": 21, "tmin": 19, "precip_mm": 22, "rh_max": 94, "wind_max_ms": 2},
            {"date": "2026-05-30", "tmax": 22, "tmin": 19, "precip_mm": 25, "rh_max": 95, "wind_max_ms": 2},
            {"date": "2026-05-31", "tmax": 23, "tmin": 19, "precip_mm": 14, "rh_max": 90, "wind_max_ms": 3},
            {"date": "2026-06-01", "tmax": 24, "tmin": 19, "precip_mm": 8,  "rh_max": 86, "wind_max_ms": 3}
          ]
        },
        "ndvi_override": null,
        "bulletin_override": ["通报 1", "通报 4"],
        "expected_decision": {
          "peril_code": "HEAVY_RAIN_AT_HARVEST",
          "risk_level": "高",
          "matched_history_case": "CASE-001"
        }
      }
    },
    {
      "id": "DEMO-WAN-FROST",
      "label": "晚霜冻场景：黑龙江绥化春玉米苗期 5/27 夜间 -2°C",
      "narrative_hook": "演讲到'东北用户' 时按这个，对比第一个场景说明系统会按地理/作物分别决策。",
      "inject": {
        "parcel_id": "P-HLJ-SUIHUA-003",
        "weather_override": {
          "daily": [
            {"date": "2026-05-26", "tmax": 18, "tmin": 6,  "precip_mm": 0, "rh_max": 60, "wind_max_ms": 4},
            {"date": "2026-05-27", "tmax": 15, "tmin": -2, "precip_mm": 0, "rh_max": 45, "wind_max_ms": 2, "_note": "辐射降温夜晚"},
            {"date": "2026-05-28", "tmax": 16, "tmin": 4,  "precip_mm": 0, "rh_max": 55, "wind_max_ms": 3},
            {"date": "2026-05-29", "tmax": 18, "tmin": 7,  "precip_mm": 0, "rh_max": 60, "wind_max_ms": 3}
          ]
        },
        "ndvi_override": null,
        "bulletin_override": ["通报 2"],
        "expected_decision": {
          "peril_code": "LATE_FROST",
          "risk_level": "中",
          "matched_history_case": null
        }
      }
    },
    {
      "id": "DEMO-HAIL",
